//5. Sensor DHT11

// Inclui biblioteca do DHT
#include <DHT.h>
// Define o pino do sensor
#define DHTPIN 3
// Define o tipo do sensor
#define DHTTYPE DHT11
// Cria objeto do sensor
DHT dht(DHTPIN, DHTTYPE);
void setup() {
  // Inicia serial
  Serial.begin(9600);
  // Inicializa sensor
  dht.begin();
}
void loop() {
  // Lê temperatura
  float temp = dht.readTemperature();
  // Lê umidade
  float hum = dht.readHumidity();
  // Mostra temperatura
  Serial.print("Temp: ");
  Serial.print(temp);
  // Mostra umidade
  Serial.print(" Hum: ");
  Serial.println(hum);
  // Aguarda 2 segundos
  delay(2000);
}
