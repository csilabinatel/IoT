// Define pino do botão
#define BOTAO 4
void setup() {
6. Botão
  // Define botão como entrada com pull-up interno
  pinMode(BOTAO, INPUT_PULLUP);
  // Inicia serial
  Serial.begin(9600);
}
void loop() {
  // Se botão pressionado (LOW)
  if (digitalRead(BOTAO) == LOW) {
    // Envia 1
    Serial.println(1);
  } 
  else {
    // Envia 0
    Serial.println(0);
  }
  // Pequeno delay
  delay(200);
}
