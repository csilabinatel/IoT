//LoRa RX - LED

// Inclui biblioteca SPI (comunicação com o módulo LoRa)
#include <SPI.h>
// Inclui biblioteca do LoRa
#include <LoRa.h>
// Define o pino NSS (Chip Select)
#define NSS 10
// Define o pino de RESET do LoRa
#define RST 9
// Define o pino de interrupção (DIO0)
#define DIO0 2
// Define o pino do LED
#define LED 7
void setup() {
  // Define o LED como saída
  pinMode(LED, OUTPUT);
  // Inicia comunicação serial
  Serial.begin(9600);
  // Configura os pinos do LoRa
  LoRa.setPins(NSS, RST, DIO0);
  // Inicializa o LoRa na frequência 915 MHz
  LoRa.begin(915E6);
}
void loop() {
  // Verifica se chegou pacote LoRa
  int packetSize = LoRa.parsePacket();
  // Se recebeu algo
  if (packetSize) {
    // String para armazenar mensagem
    String msg = "";
    // Lê todos os bytes recebidos
    while (LoRa.available()) {
      msg += (char)LoRa.read();
    }
    // Se mensagem for "1"
    if (msg == "1") {
      // Liga o LED
      digitalWrite(LED, HIGH);
    } 
    else {
      // Desliga o LED
      digitalWrite(LED, LOW);
    }
  }
}
