// Define o pino digital do LDR
#define LDR 7  // pino digital

void setup() {
  // Inicia serial
  Serial.begin(9600);

  // Define o pino como entrada
  pinMode(LDR, INPUT);
}

void loop() {
  // Lê valor digital (HIGH ou LOW)
  int estado = digitalRead(LDR);

  // Mostra no serial
  Serial.println(estado);

  // Espera 1 segundo
  delay(1000);
}
