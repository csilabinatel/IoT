//2. Sensor de Umidade

// Define o pino analógico do sensor
#define SENSOR A0
void setup() {
  // Inicia comunicação serial
  Serial.begin(9600);
}
void loop() {
  // Lê valor analógico do sensor
  int valor = analogRead(SENSOR);
  // Envia valor para o monitor serial
  Serial.println(valor);
  // Aguarda 1 segundo
  delay(1000);
}
